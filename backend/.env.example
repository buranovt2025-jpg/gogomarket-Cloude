# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://api.gogomarket.uz/v1

# Database
DATABASE_URL=postgresql://gogomarket:secret@localhost:5432/gogomarket
DATABASE_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# SMS (Eskiz)
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=eskiz_password
ESKIZ_FROM=GogoMarket

# S3 / Object Storage
S3_ENDPOINT=https://s3.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=gogomarket-media
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
CDN_URL=https://cdn.gogomarket.uz

# Payment
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Firebase
FIREBASE_PROJECT_ID=gogomarket-app
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5

# CORS
ALLOWED_ORIGINS=https://gogomarket.uz,https://admin.gogomarket.uz
